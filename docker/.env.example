############################################################
# OhMyGold — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
############################################################

# ---- Supabase ----
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password
POSTGRES_DB=postgres
POSTGRES_PORT=54322

JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# These are generated by Supabase — replace with your values
ANON_KEY=your-anon-key-here
SERVICE_ROLE_KEY=your-service-role-key-here

# ---- Ports ----
KONG_HTTP_PORT=54320
KONG_HTTPS_PORT=8443
AUTH_PORT=54323
STUDIO_PORT=54321

# ---- URLs ----
API_EXTERNAL_URL=http://localhost:54320
SITE_URL=http://localhost:5173
# Comma-separated list of additional allowed redirect URLs (for mobile deep links)
ADDITIONAL_REDIRECT_URLS=ohmygold://auth/callback,exp://localhost:19000/auth/callback

# ---- Studio ----
STUDIO_DEFAULT_ORGANIZATION=OhMyGold Dev
STUDIO_DEFAULT_PROJECT=OhMyGold Local
SUPABASE_PUBLIC_URL=http://localhost:54320

# ---- Auth Configuration ----
ENABLE_EMAIL_SIGNUP=true
# Set to true in dev to skip email confirmation (NOT for production)
ENABLE_EMAIL_AUTOCONFIRM=false
DISABLE_SIGNUP=false
PASSWORD_MIN_LENGTH=8
ENABLE_MFA=true

# ---- SMTP (Email) ----
# Using SendGrid / Mailgun / Postmark in production
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key-here
SMTP_ADMIN_EMAIL=noreply@ohmygold.fr
SMTP_SENDER_NAME=OhMyGold

# ---- OAuth Providers ----
ENABLE_GOOGLE_SIGNUP=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

ENABLE_APPLE_SIGNUP=false
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ---- PostgREST ----
PGRST_DB_SCHEMAS=public,storage,graphql_public

# ---- Web App ----
VITE_SUPABASE_URL=http://localhost:54320
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# NEVER expose service role key in frontend — server-side only
# VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
