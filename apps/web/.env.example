# ============================================================
# OhMyGold Web App — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# ---- Supabase (Public — safe to expose to browser) ----
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ---- App Config ----
VITE_APP_NAME=OhMyGold
VITE_APP_URL=http://localhost:5173

# ---- i18n ----
VITE_DEFAULT_LOCALE=fr

# ---- Stripe (Public key — safe to expose) ----
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ============================================================
# ⚠️  NEVER add SUPABASE_SERVICE_ROLE_KEY with VITE_ prefix!
#     Service role keys must ONLY exist in server-side code
#     (Edge Functions, API routes) — never in client bundles.
# ============================================================

# ---- Server-only (Edge Functions / API routes only) ----
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
