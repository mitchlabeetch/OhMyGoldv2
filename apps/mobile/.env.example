# ============================================================
# OhMyGold Mobile App — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ---- Supabase ----
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ---- App Config ----
EXPO_PUBLIC_APP_NAME=OhMyGold
EXPO_PUBLIC_APP_SCHEME=ohmygold

# ---- Push Notifications (Expo) ----
# EXPO_PUBLIC_PUSH_PROJECT_ID=your-expo-project-id

# ---- Stripe (Public key) ----
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ============================================================
# ⚠️  Use EXPO_PUBLIC_ prefix for values that are safe to
#     embed in the client bundle. Never use this prefix for
#     secrets (service role keys, private API keys, etc.).
# ============================================================
